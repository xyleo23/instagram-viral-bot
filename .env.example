# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=0

# Database
DATABASE_URL=sqlite+aiosqlite:///./instagram_bot.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Orshot API (генерация изображений)
ORSHOT_API_KEY=your_orshot_api_key_here
ORSOT_TEMPLATE_ID=2685

# Yandex.Disk (опционально)
YANDEX_DISK_TOKEN=your_yandex_disk_oauth_token

# Apify (парсинг Instagram)
APIFY_TOKEN=your_apify_api_token_here
APIFY_INSTAGRAM_ACT_ID=your_apify_instagram_actor_id
# Устаревшее (обратная совместимость):
# APIFY_API_KEY=your_apify_api_key_here

# Google Services (опционально)
GOOGLE_SHEETS_ID=your_google_sheets_id_here
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json

# Instagram publishing (Instagrapi)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
# INSTAGRAM_PROXY=http://user:pass@host:port

# Instagram (авторы для парсинга)
INSTAGRAM_AUTHORS=sanyaagainst,theivansergeev,ivan.loginov_ai,provotorov_pro,generalov_ai

# Фильтры постов
MIN_LIKES=5000
MAX_POST_AGE_DAYS=3
MIN_TEXT_LENGTH=100

# Celery (опционально, по умолчанию Redis)
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Scheduler (cron)
PARSE_CRON=0 */6 * * *
PROCESS_CRON=0 * * * *

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
